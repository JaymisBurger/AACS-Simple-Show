PORT=5000
NODE_ENV=development

FRONTEND_ORIGIN=http://localhost:5173
BACKEND_PUBLIC_URL=http://localhost:5000

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=aacs_vendor_booths
# Optional for macOS MySQL installer if TCP is not enabled:
# DB_SOCKET_PATH=/tmp/mysql.sock

JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=8h

UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10
VENDOR_LOGO_MAX_SIZE_MB=5
INVITATION_TOKEN_EXPIRES_HOURS=72
PASSWORD_RESET_TOKEN_EXPIRES_HOURS=24
PUBLIC_TOKEN_EXPIRES_DAYS=90

SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=replace_with_dev_password

DEMO_SEED_CONFIRM=
DEMO_ADMIN_PASSWORD=
DEMO_VENDOR_PASSWORD=
DEMO_CLEANUP_CONFIRM=
